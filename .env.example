# ==========================================
# DPX Discord Bot Configuration Template
# Rename this file to .env and fill in the values
# ==========================================

# --- Discord Configuration ---
DISCORD_TOKEN=your_bot_token_here
LOG_CHANNEL_ID=123456789012345678

# --- PostgreSQL Database Settings ---
POSTGRES_USER=dpx_discord_bot
POSTGRES_PASSWORD=db_password_change_me
POSTGRES_DB=dpx_discord_bot

# --- Redis Cache Settings ---
REDIS_PASSWORD=redis_password_change_me

# --- MinIO (S3) Storage Settings ---
MINIO_ROOT_USER=dpx_discord_bot
MINIO_ROOT_PASSWORD=minio_password_change_me

# --- Other Parameters ---
MAX_MESSAGES_SAVED=1000
MUSIC_MAX_QUEUE_LEN=500
MUSIC_BITRATE=96
MUSIC_GD_SIZE_LIMIT_MB=100
